{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "registry:build": {
      "inputs": ["registry.json", "registry/**", "scripts/build-registry.mjs"],
      "outputs": ["public/r/**", "public/llms.txt"]
    },
    "build": {
      "dependsOn": ["^build", "registry:build"],
      "outputs": ["dist/**"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "dev": {
      "dependsOn": ["registry:build"],
      "cache": false,
      "persistent": true
    }
  }
}
